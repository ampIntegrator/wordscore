        {
            "key": "field_use_custom_fonts",
            "label": "Utiliser des polices personnalisées",
            "name": "use_custom_fonts",
            "type": "true_false",
            "message": "Désactiver Google Fonts et utiliser mes propres fichiers de polices",
            "default_value": 0,
            "ui": 1,
            "wrapper": {
                "width": "50"
            }
        },
        {
            "key": "field_heading_custom_font_file",
            "label": "Fichier de police pour les Headings",
            "name": "heading_custom_font_file",
            "type": "file",
            "instructions": "Upload un fichier .woff2 pour vos titres (h1-h6)",
            "return_format": "url",
            "mime_types": "woff,woff2,ttf,otf",
            "conditional_logic": [
                [
                    {
                        "field": "field_use_custom_fonts",
                        "operator": "==",
                        "value": "1"
                    }
                ]
            ],
            "wrapper": {
                "width": "50"
            }
        },
        {
            "key": "field_heading_custom_font_weight",
            "label": "Font-weight de ce fichier (Headings)",
            "name": "heading_custom_font_weight",
            "type": "select",
            "instructions": "Précisez le font-weight du fichier uploadé",
            "choices": {
                "300": "Light (300)",
                "400": "Regular (400)",
                "500": "Medium (500)",
                "600": "Semi-Bold (600)",
                "700": "Bold (700)",
                "800": "Extra-Bold (800)",
                "900": "Black (900)"
            },
            "default_value": "700",
            "conditional_logic": [
                [
                    {
                        "field": "field_use_custom_fonts",
                        "operator": "==",
                        "value": "1"
                    }
                ]
            ],
            "wrapper": {
                "width": "50"
            }
        },
        {
            "key": "field_body_custom_font_file",
